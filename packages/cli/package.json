{
  "name": "@medxai/cli",
  "version": "0.1.0",
  "description": "MedXAI FHIR Engine CLI — Operational Console for FHIR R4 structure analysis and validation",
  "homepage": "https://medxai.com.cn",
  "license": "Apache-2.0",
  "author": "Fangjun <fangjun20208@gmail.com>",
  "keywords": [
    "fhir",
    "fhir-r4",
    "healthcare",
    "hl7",
    "typescript",
    "cli",
    "validator",
    "fhirpath",
    "medical",
    "interoperability"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/medxaidev/medxai.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/medxaidev/medxai/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "type": "module",
  "bin": {
    "medxai": "./dist/bin/medxai.mjs"
  },
  "main": "./dist/esm/index.mjs",
  "types": "./dist/lib/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/lib/index.d.ts",
        "default": "./dist/esm/index.mjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && tsc && node ./scripts/esbuild.mjs",
    "dev": "node --import tsx ./src/bin/medxai.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@medxai/fhir-core": "0.1.0"
  },
  "devDependencies": {
    "typescript": "5.9.3",
    "@types/node": "25.2.0",
    "rimraf": "6.1.2",
    "esbuild": "0.27.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
